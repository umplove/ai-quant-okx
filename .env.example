# OKX API credentials. Use Demo Trading keys first.
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Keep demo mode enabled for V1.
OKX_DEMO=true
OKX_BASE_URL=https://www.okx.com
OKX_SIMULATED_TRADING_HEADER=true

# Safety: orders are not sent unless this is true.
TRADING_ENABLED=false
ALLOW_LIVE_TRADING=false

# Trading universe.
SYMBOLS=BTC-USDT,ETH-USDT
BAR=1H
DB_PATH=data/bot.sqlite3

# Strategy defaults.
EMA_FAST=20
EMA_SLOW=200
RSI_PERIOD=14
RSI_LOW=35

# Risk defaults.
MAX_TRADE_FRACTION=0.10
MAX_SYMBOL_FRACTION=0.20
STOP_LOSS_PCT=0.015
TAKE_PROFIT_PCT=0.03
TRAILING_STOP_PCT=0.01
MAX_DAILY_LOSS_PCT=0.03
MAX_CONSECUTIVE_LOSSES=3

# Information momentum pilot.
SCAN_INTERVAL_SECONDS=30
CANDIDATE_TOP_N=20
RISK_PER_TRADE_USDT=200
TARGET_POSITION_USDT=1000
STOP_MODE=percent
INITIAL_STOP_LOSS_PCT=0.20
FIXED_STOP_LOSS_USDT=200
MAX_OPEN_POSITIONS=1
# Training mode: keep false for demo learning so losses do not pause the bot.
# Set true only when you want daily-loss/consecutive-loss/symbol pause halts.
RISK_HALT_ENABLED=false
NEWS_RSS_URLS=
OKX_SKILL_SIGNAL_URLS=
NEWS_SCAN_AGGRESSIVE=true
# Public RSS, CoinGecko trending, Alternative.me Fear & Greed, Binance
# announcements, and OKX announcements are scanned without keys.
INTELLIGENCE_MAX_ITEMS=50
TRADE_REVIEW_ENABLED=true
POLYMARKET_ENABLED=false
BINANCE_SQUARE_ENABLED=false
REQUIRE_INFO_CONFIRMATION=false

# Telegram output/control mode.
TELEGRAM_MONEY_ONLY=true
TELEGRAM_CONTROLS_ENABLED=true
TELEGRAM_AUTO_REPORTS=false
MONEY_REPORT_INTERVAL_SCANS=1

# Optional notifications.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional AI review / training. MiMo-compatible defaults are intentional.
AI_REVIEW_ENABLED=false
AI_REVIEW_INTERVAL_SCANS=1
AI_REVIEW_MAX_CANDIDATES=5
AI_REVIEW_MAX_TOKENS=2000
AI_REVIEW_TIMEOUT_SECONDS=12
AI_ALWAYS_ON=true
AI_EXPLORATION_FRACTION=0.20
AI_REQUEST_RETRIES=2
AI_RETRY_BACKOFF_SECONDS=1.5
AI_TRAINING_ENABLED=true
AI_TRAINING_WORKERS=4
AI_WEEKLY_TOKEN_TARGET=1000000000
OPENAI_API_KEY=
OPENAI_MODEL=mimo-v2.5-pro
OPENAI_BASE_URL=https://api.xiaomimimo.com/v1
OPENAI_API_MODE=chat

# You can also set MIMO_API_KEY instead of OPENAI_API_KEY.
